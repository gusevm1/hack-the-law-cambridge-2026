# Copy to .env.local for local dev. Auth uses your gcloud ADC
# (run: gcloud auth application-default login).
GCP_PROJECT=hack-the-law-cambridge-2026
VERTEX_LOCATION=global
GEMINI_MODEL=gemini-2.5-flash
CORS_ORIGINS=*

# --- Database (only needed to exercise /chat locally) ---------------------
# Option A — Cloud SQL via the connector (uses your ADC):
#   INSTANCE_CONNECTION_NAME=hack-the-law-cambridge-2026:europe-west1:htl-db
#   DB_USER=htl_app
#   DB_NAME=htl
#   DB_PASSWORD=...        # gcloud secrets versions access latest --secret=htl-db-password
# Option B — a plain local Postgres:
#   DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/htl

# --- Supabase auth (leave unset to use the dev stub verifier) -------------
# SUPABASE_ISSUER=https://seowjktpscgkklvmlvep.supabase.co/auth/v1
# SUPABASE_JWKS_URL=https://seowjktpscgkklvmlvep.supabase.co/auth/v1/.well-known/jwks.json
